---
// Calculator.astro — Breakeven point + net profit comparison calculator
---

<div class="bp-calc">
  <h3 class="bp-calc-title">回本點距與淨利對比</h3>
  <p class="bp-calc-desc">輸入進場價和預期跳動，看看兩個交易所的真實成本差距。</p>

  <div class="bp-inputs">
    <div class="bp-field">
      <label>進場幣價 (USDT)</label>
      <input type="number" id="bpEntryPrice" value="3000" min="0" step="any" />
    </div>
    <div class="bp-field">
      <label>預期賺取跳動點數</label>
      <input type="number" id="bpMovePoints" value="10" min="0" step="any" />
    </div>
    <div class="bp-field">
      <label>交易倉位 (顆數)</label>
      <input type="number" id="bpPositionSize" value="1" min="0" step="any" />
    </div>
  </div>

  <div class="bp-cards">

    <!-- BitMart -->
    <div class="bp-exchange-card">
      <div class="bp-exchange-header bp-header--bma">BitMart <span>精算流</span></div>

      <div class="bp-scenario">
        <div class="bp-scenario-head">
          <span>全掛單（Maker 進 / Maker 出）</span>
          <span class="bp-rate-tag">總費率 0.04%</span>
        </div>
        <div class="bp-row">
          <span>回本所需跳動點數</span>
          <span class="bp-val" id="bmMakerBe">0.00 點</span>
        </div>
        <div class="bp-row bp-row--profit">
          <span>扣除手續費真實淨利</span>
          <span class="bp-val" id="bmMakerNet">0.00 USDT</span>
        </div>
      </div>

      <div class="bp-scenario">
        <div class="bp-scenario-head">
          <span>全市價（Taker 進 / Taker 出）</span>
          <span class="bp-rate-tag">總費率 0.12%</span>
        </div>
        <div class="bp-row">
          <span>回本所需跳動點數</span>
          <span class="bp-val" id="bmTakerBe">0.00 點</span>
        </div>
        <div class="bp-row bp-row--profit">
          <span>扣除手續費真實淨利</span>
          <span class="bp-val" id="bmTakerNet">0.00 USDT</span>
        </div>
      </div>

      <a href="https://www.bitmart.com/zh-TW/invite/cMPDb9" target="_blank" rel="noopener" class="bp-cta">註冊 BitMart →</a>
    </div>

    <!-- MEXC -->
    <div class="bp-exchange-card">
      <div class="bp-exchange-header bp-header--mexc">MEXC <span>市價流</span></div>

      <div class="bp-scenario">
        <div class="bp-scenario-head">
          <span>全掛單（Maker 進 / Maker 出）</span>
          <span class="bp-rate-tag">總費率 0.08%</span>
        </div>
        <div class="bp-row">
          <span>回本所需跳動點數</span>
          <span class="bp-val" id="mexcMakerBe">0.00 點</span>
        </div>
        <div class="bp-row bp-row--profit">
          <span>扣除手續費真實淨利</span>
          <span class="bp-val" id="mexcMakerNet">0.00 USDT</span>
        </div>
      </div>

      <div class="bp-scenario">
        <div class="bp-scenario-head">
          <span>全市價（Taker 進 / Taker 出）</span>
          <span class="bp-rate-tag">總費率 0.08%</span>
        </div>
        <div class="bp-row">
          <span>回本所需跳動點數</span>
          <span class="bp-val" id="mexcTakerBe">0.00 點</span>
        </div>
        <div class="bp-row bp-row--profit">
          <span>扣除手續費真實淨利</span>
          <span class="bp-val" id="mexcTakerNet">0.00 USDT</span>
        </div>
      </div>

      <a href="https://www.mexc.com/zh-TW/acquisition/custom-sign-up?shareCode=mexc-Xplan" target="_blank" rel="noopener" class="bp-cta">註冊 MEXC →</a>
    </div>

  </div>
</div>

<script is:inline>
(function() {
  var entryPrice = document.getElementById('bpEntryPrice');
  var movePoints = document.getElementById('bpMovePoints');
  var positionSize = document.getElementById('bpPositionSize');

  var rates = {
    bmMaker: 0.0004,   // 0.02% × 2
    bmTaker: 0.0012,   // 0.06% × 2
    mexcMaker: 0.0008,  // 0.04% × 2
    mexcTaker: 0.0008   // 0.04% × 2
  };

  function fmt(n) {
    return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function calc() {
    var price = parseFloat(entryPrice.value) || 0;
    var move = parseFloat(movePoints.value) || 0;
    var size = parseFloat(positionSize.value) || 0;
    var posValue = price * size;
    var grossProfit = move * size;

    function update(beId, netId, rate) {
      var bePts = price * rate;
      var fee = posValue * rate;
      var net = grossProfit - fee;
      document.getElementById(beId).textContent = fmt(bePts) + ' 點';
      var netEl = document.getElementById(netId);
      netEl.textContent = (net >= 0 ? '+' : '') + fmt(net) + ' USDT';
      netEl.className = 'bp-val ' + (net >= 0 ? 'bp-profit' : 'bp-loss');
    }

    update('bmMakerBe', 'bmMakerNet', rates.bmMaker);
    update('bmTakerBe', 'bmTakerNet', rates.bmTaker);
    update('mexcMakerBe', 'mexcMakerNet', rates.mexcMaker);
    update('mexcTakerBe', 'mexcTakerNet', rates.mexcTaker);
  }

  [entryPrice, movePoints, positionSize].forEach(function(el) {
    el.addEventListener('input', calc);
  });

  calc();
})();
</script>

<style>
  .bp-calc {
    max-width: 100%;
  }

  .bp-calc-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .bp-calc-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .bp-inputs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .bp-field label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .bp-field input {
    width: 100%;
    padding: 0.6rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .bp-field input:focus {
    outline: none;
    border-color: var(--amber);
  }

  .bp-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .bp-exchange-card {
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
  }

  .bp-exchange-header {
    padding: 1rem 1.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }

  .bp-exchange-header span {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }

  .bp-header--bma {
    border-left: 3px solid var(--amber);
  }

  .bp-header--mexc {
    border-left: 3px solid var(--text);
  }

  .bp-scenario {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .bp-scenario:last-of-type {
    border-bottom: none;
  }

  .bp-scenario-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
  }

  .bp-rate-tag {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--amber);
    border: 1px solid rgba(196, 168, 74, 0.3);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .bp-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--text-muted);
    padding: 0.35rem 0;
  }

  .bp-row--profit {
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }

  .bp-val {
    font-weight: 700;
    color: var(--text);
  }

  .bp-profit {
    color: var(--amber) !important;
  }

  .bp-loss {
    color: var(--red, #C87840) !important;
  }

  .bp-cta {
    display: block;
    padding: 1rem 1.5rem;
    font-size: 0.85rem;
    color: var(--amber);
    text-decoration: none;
    letter-spacing: 0.06em;
    border-top: 1px solid var(--border);
    transition: opacity 0.3s;
    margin-top: auto;
  }

  .bp-cta:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .bp-inputs {
      grid-template-columns: 1fr;
    }

    .bp-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
