<style>
  .nav-extras {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-icon {
    display: flex;
    align-items: center;
    color: var(--text-muted);
    transition: color 0.3s;
  }

  .nav-icon:hover {
    color: var(--text);
  }

  .nav-icon svg {
    width: 18px;
    height: 18px;
  }

  .nav-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-left: 1rem;
    border-left: 1px solid var(--border);
  }

  .nav-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ADE80;
    animation: breathe 2s ease-in-out infinite;
  }

  @keyframes breathe {
    0%, 100% { opacity: 1; box-shadow: 0 0 4px #4ADE80; }
    50% { opacity: 0.4; box-shadow: 0 0 8px #4ADE80, 0 0 16px rgba(74, 222, 128, 0.3); }
  }

  .nav-status-text {
    font-size: 0.75rem;
    font-weight: 600;
    color: #4ADE80;
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    .nav-extras {
      position: fixed;
      top: 16px;
      right: calc(8vw + 42px);
      z-index: 101;
      gap: 0.75rem;
    }

    .nav-status {
      padding-left: 0.75rem;
    }

    .nav-status-text {
      font-size: 0.7rem;
    }

    .nav-icon svg {
      width: 16px;
      height: 16px;
    }
  }
</style>
