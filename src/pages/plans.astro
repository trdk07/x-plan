---
// plans.astro — 方案頁
import Layout from '../layouts/Layout.astro';
import Calculator from '../components/Calculator.astro';
---

<Layout title="方案" description="先了解 X翻倉計畫 的打法、手續費、入群條件，再決定你的路線。">

  <!-- ============================================================
       Page Hero
       ============================================================ -->
  <section class="page-hero">
    <div class="container">
      <span class="section-number">01</span>
      <h1 class="page-title" data-reveal="up">先了解這個打法。</h1>
      <span class="amber-rule" style="margin-top: 2rem;"></span>
    </div>
  </section>

  <!-- ============================================================
       Section 1 — 打單方式（完整）
       ============================================================ -->
  <section class="full-method">
    <div class="container">
    <div class="full-method-body" data-stagger>
      <p data-reveal="up">
        我用 1 分鐘或 3 分鐘 K 線打單<br />
        配合玄學流日判斷當天能量方向<br />
        找到進場點，設好槓桿，短時間內出場。
      </p>

      <h3 class="method-question" data-reveal="up">為什麼不看更大的時區？</h3>

      <p data-reveal="up">
        不是不能看，是現在的市場<br />
        流動性變慢、長時區的方向不好判斷<br />
        持倉一晚上，換來的可能是焦慮和利潤回吐。
      </p>

      <p data-reveal="up">
        我選擇把視野放小——<br />
        每一筆單都有意識，每一次出場都是決定。
      </p>

      <p data-reveal="up">
        這個打法有爭議<br />
        高槓桿、高手續費、高頻率<br />
        但對我來說，這是目前市場裡<br />
        最能讓人睡得著、也拿得到利潤的方式。
      </p>

      <p class="method-invite" data-reveal="up">
        如果這個打法讓你有感覺，往下看。
      </p>
    </div>
    </div>
  </section>

  <!-- ============================================================
       Section 2 — 手續費公式
       ============================================================ -->
  <section class="fee-section" data-reveal="up">
    <div class="container">
    <span class="section-number">02</span>
    <h2 class="fee-title">手續費怎麼算，先搞清楚。</h2>

    <div class="fee-formula">
      <p class="formula-main">手續費 ＝ 總倉位價值 × 費率</p>
      <p class="formula-note">（不是你的本金，是你撬動的總部位）</p>
    </div>

    <div class="fee-exchanges">
      <div class="fee-exchange-col">
        <h3 class="fee-exchange-name">BitMart</h3>
        <p class="fee-exchange-rate">Maker 0.02% / Taker 0.06%　·　最高 200×</p>

        <div class="scenarios">
          <div class="scenario">
            <span class="scenario-label">10× 槓桿 / 100U 本金</span>
            <p class="scenario-calc">1,000U 部位 → Taker 0.06%</p>
            <p class="scenario-fee">0.60 USDT <em>（單邊）</em></p>
            <p class="scenario-insight">來回 1.2U，佔本金 1.2%</p>
          </div>
          <div class="scenario">
            <span class="scenario-label">50× 槓桿 / 100U 本金</span>
            <p class="scenario-calc">5,000U 部位 → Taker 0.06%</p>
            <p class="scenario-fee">3.00 USDT <em>（單邊）</em></p>
            <p class="scenario-insight">來回 6U，佔本金 6%</p>
          </div>
          <div class="scenario">
            <span class="scenario-label">200× 槓桿 / 100U 本金</span>
            <p class="scenario-calc">20,000U 部位 → Taker 0.06%</p>
            <p class="scenario-fee">12.00 USDT <em>（單邊）</em></p>
            <p class="scenario-insight">來回 24U，佔本金 24%</p>
          </div>
        </div>
      </div>

      <div class="fee-exchange-col">
        <h3 class="fee-exchange-name">MEXC</h3>
        <p class="fee-exchange-rate">統一費率 0.04%　·　最高 500×</p>

        <div class="scenarios">
          <div class="scenario">
            <span class="scenario-label">10× 槓桿 / 100U 本金</span>
            <p class="scenario-calc">1,000U 部位 → 0.04%</p>
            <p class="scenario-fee">0.40 USDT <em>（單邊）</em></p>
            <p class="scenario-insight">來回 0.8U，佔本金 0.8%</p>
          </div>
          <div class="scenario">
            <span class="scenario-label">200× 槓桿 / 100U 本金</span>
            <p class="scenario-calc">20,000U 部位 → 0.04%</p>
            <p class="scenario-fee">8.00 USDT <em>（單邊）</em></p>
            <p class="scenario-insight">來回 16U，佔本金 16%</p>
          </div>
          <div class="scenario">
            <span class="scenario-label">500× 槓桿 / 100U 本金</span>
            <p class="scenario-calc">50,000U 部位 → 0.04%</p>
            <p class="scenario-fee">20.00 USDT <em>（單邊）</em></p>
            <p class="scenario-insight">來回 40U——極致資金效率，但紀律是前提</p>
          </div>
        </div>
      </div>
    </div>

    <p class="fee-takeaway" data-reveal="fade">
      同樣的倉位，MEXC 的 Taker 成本比 BitMart 低 33%。<br />
      而且 Maker 掛單也是 0.04%——市價逃命不會被多收。
    </p>
    </div>
  </section>

  <!-- ============================================================
       Section 2.5 — 回本點距白話解說
       ============================================================ -->
  <section class="breakeven-section">
    <div class="container">
    <h2 class="breakeven-title" data-reveal="up">白話講：漲幾點才開始賺？</h2>
    <p class="breakeven-intro" data-reveal="fade">
      手續費不是一個數字而已——它決定了你開倉後，<br />
      幣價要往你的方向跑多遠，你才開始真正賺錢。
    </p>

    <div class="breakeven-cases" data-stagger>

      <!-- ETH 案例 -->
      <div class="breakeven-case" data-reveal="up">
        <span class="breakeven-case-label">案例一 — ETH 進場價 3,000 U</span>
        <p class="breakeven-case-desc">假設你在 3,000U 做多，ETH 要漲到多少才回本？</p>

        <div class="breakeven-compare">
          <div class="breakeven-col">
            <h4>BitMart</h4>
            <div class="breakeven-item">
              <span class="breakeven-type">全掛單（Maker 進出）</span>
              <span class="breakeven-rate">總費率 0.04%</span>
              <p class="breakeven-math">3,000 × 0.04% = <strong>1.2 點</strong></p>
              <p class="breakeven-result">ETH 漲到 3,001.2 就打平<br />之後每跳 1 點都是純利潤</p>
            </div>
            <div class="breakeven-item">
              <span class="breakeven-type">全市價（Taker 進出）</span>
              <span class="breakeven-rate">總費率 0.12%</span>
              <p class="breakeven-math">3,000 × 0.12% = <strong>3.6 點</strong></p>
              <p class="breakeven-result">需要漲到 3,003.6 才回本</p>
            </div>
          </div>
          <div class="breakeven-col">
            <h4>MEXC</h4>
            <div class="breakeven-item">
              <span class="breakeven-type">不管掛單或市價</span>
              <span class="breakeven-rate">統一費率 0.08%</span>
              <p class="breakeven-math">3,000 × 0.08% = <strong>2.4 點</strong></p>
              <p class="breakeven-result">漲過 3,002.4 就開始賺<br />不用擔心掛單沒成交被吃 Taker</p>
            </div>
          </div>
        </div>
      </div>

      <!-- BTC 案例 -->
      <div class="breakeven-case" data-reveal="up">
        <span class="breakeven-case-label">案例二 — BTC 進場價 60,000 U</span>
        <p class="breakeven-case-desc">BTC 價格大，跳動點數的成本感更強烈。</p>

        <div class="breakeven-compare">
          <div class="breakeven-col">
            <h4>BitMart</h4>
            <div class="breakeven-item">
              <span class="breakeven-type">全掛單</span>
              <span class="breakeven-rate">0.04%</span>
              <p class="breakeven-math">60,000 × 0.04% = <strong>24 點</strong></p>
              <p class="breakeven-result">BTC 漲過 24 點即回本</p>
            </div>
            <div class="breakeven-item">
              <span class="breakeven-type">全市價</span>
              <span class="breakeven-rate">0.12%</span>
              <p class="breakeven-math">60,000 × 0.12% = <strong>72 點</strong></p>
              <p class="breakeven-result">BTC 漲過 72 點才回本</p>
            </div>
          </div>
          <div class="breakeven-col">
            <h4>MEXC</h4>
            <div class="breakeven-item">
              <span class="breakeven-type">統一費率</span>
              <span class="breakeven-rate">0.08%</span>
              <p class="breakeven-math">60,000 × 0.08% = <strong>48 點</strong></p>
              <p class="breakeven-result">不管市價還是限價<br />漲過 48 點就是純利</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <p class="breakeven-bottom" data-reveal="fade">
      看到差距了嗎？<br />
      BitMart 掛單最省，但你必須確保成交。<br />
      MEXC 不管怎麼打，成本都一樣——對市價派來說，這就是主場優勢。
    </p>
    </div>
  </section>

  <!-- ============================================================
       Section 3 — 200倍比較
       ============================================================ -->
  <section class="leverage-compare" data-reveal="up">
    <div class="container">
    <span class="section-number">03</span>
    <h2 class="compare-title">同樣 100U，你撬動多少？</h2>
    <p class="compare-subtitle">不同交易所、不同槓桿，控制的部位完全不同。</p>

    <div class="compare-table" data-stagger>
      <div class="compare-row" data-reveal="up">
        <span class="compare-leverage">10×</span>
        <span class="compare-dots">··················</span>
        <span class="compare-result">1,000U</span>
        <span class="compare-exchange">BitMart · MEXC</span>
      </div>
      <div class="compare-row" data-reveal="up">
        <span class="compare-leverage">50×</span>
        <span class="compare-dots">··················</span>
        <span class="compare-result">5,000U</span>
        <span class="compare-exchange">BitMart · MEXC</span>
      </div>
      <div class="compare-row compare-row--big" data-reveal="up">
        <span class="compare-leverage compare-leverage--big">200×</span>
        <span class="compare-dots">··················</span>
        <span class="compare-result compare-result--big">20,000U</span>
        <span class="compare-exchange">BitMart 最高 · MEXC</span>
      </div>
      <div class="compare-row compare-row--big" data-reveal="up">
        <span class="compare-leverage compare-leverage--big" style="color: var(--text);">500×</span>
        <span class="compare-dots">··················</span>
        <span class="compare-result compare-result--big">50,000U</span>
        <span class="compare-exchange" style="color: var(--amber);">MEXC 限定</span>
      </div>
    </div>

    <div class="compare-note" data-reveal="up">
      <p>我們用全倉方式做單<br />整個帳戶都是你的緩衝，不是只有單筆保證金。</p>
      <p>
        真正的保護不是帳戶餘額<br />
        是你清楚知道自己為什麼在這個位置進場<br />
        以及什麼時候應該出去。
      </p>
    </div>

    <p class="compare-close" data-reveal="up">Know why you're in. Know when to leave.</p>
    </div>
  </section>

  <!-- ============================================================
       Section 4 — 計算機
       ============================================================ -->
  <section class="calc-section" data-reveal="scale">
    <div class="container">
      <span class="section-number" style="text-align:center; display:block; margin-bottom:1.5rem;">04 &nbsp; 試算器</span>
      <Calculator />
    </div>
  </section>

  <!-- ============================================================
       Section 5 — 兩條路
       ============================================================ -->
  <section class="two-paths">
    <div class="container">
    <span class="section-number" style="margin-bottom:2rem; display:block;">05</span>
    <h2 class="paths-title" data-reveal="up">你想要什麼？</h2>

    <div class="paths-grid">
      <div class="path-left" data-reveal="left">
        <h3 class="path-name">X翻倉計畫</h3>
        <p class="path-tagline">限收 30 人，有篩選<br />免費開始，一個月後再談。</p>

        <ul class="path-list">
          <li>— 交易指標（一個月免費）</li>
          <li>— 玄學日報</li>
          <li>— 加密貨幣 AI監控</li>
          <li>— 妖幣監測</li>
          <li>— 教學 + 真實交易紀錄</li>
          <li>— 一起在市場裡活下去的群體</li>
        </ul>

        <a href="https://tally.so/r/RGYNNl" target="_blank" rel="noopener" class="arrow-link">→ 申請入群 &nbsp;<em>Apply now</em></a>
      </div>

      <div class="paths-divider" aria-hidden="true"></div>

      <div class="path-right" data-reveal="right">
        <h3 class="path-name">單獨訂閱</h3>
        <p class="path-tagline">不入群，直接用<br />按需購買，沒有綁定。</p>

        <ul class="path-list">
          <li>— 玄學日報 15U / 月</li>
          <li>— 妖幣監測 20U / 月</li>
          <li>— 交易指標 100U / 3 個月</li>
          <li>— 不需要入群</li>
          <li>— 換回自己的交易所也能用</li>
        </ul>

        <a href="/tools" class="arrow-link">→ 查看工具訂閱 &nbsp;<em>Subscribe only</em></a>
      </div>
    </div>
    </div>
  </section>

  <!-- ============================================================
       Section 6 — 路線 A
       ============================================================ -->
  <section class="route-a" data-reveal="up">
    <div class="container">
    <span class="section-number">06 &nbsp; 路線 A — 入群</span>
    <h2 class="route-title">這不是一般的交易社群</h2>

    <div class="route-body">
      <p>
        你會拿到指標、玄學日報、交易紀錄<br />
        以及一個陪你在市場裡活下去的群體
      </p>

      <p>
        在這裡，教學只是個過程<br />
        我更期待的是，當你摸透了這套遊戲規則後<br />
        有一天能反過來提醒我、甚至教我<br />
        交易不該是孤軍奮戰<br />
        看懂盤面的人互相照看<br />
        這才是能長久存活的良善循環
      </p>

      <p>
        前一個月免費<br />
        之後，只要你保持著交易紀律、穩定地留在市場裡<br />
        （別誤會，我不是要你頻繁刷交易量）<br />
        費用的事我們再談
      </p>

      <p>
        但有言在先：如果你的虧損失去控制，我會請你離開
      </p>

      <p class="route-note">
        這絕對不是懲罰<br />
        而是當交易變成賭博、當心態開始失衡<br />
        或是帳面數字已經超過你能承載的負荷時<br />
        你最需要的是強制登出，而不是繼續待在群裡上頭<br />
        保護你的生活，永遠比任何一筆交易更重要
      </p>

      <div class="route-meta">
        <p><strong>每期名額：30 人</strong></p>
        <p>入群需要填寫申請表，我會篩選</p>
      </div>
    </div>

    <a href="https://tally.so/r/RGYNNl" target="_blank" rel="noopener" class="arrow-link" style="margin-top: 2rem; display: inline-flex;">
      → 申請入群 &nbsp;<em>Apply now</em>
    </a>
    </div>
  </section>

  <!-- ============================================================
       Section 7 — 路線 B
       ============================================================ -->
  <section class="route-b" data-reveal="up">
    <div class="container">
    <span class="section-number">07 &nbsp; 路線 B — 單獨訂閱</span>

    <div class="route-b-grid route-b-grid--three">
      <div class="route-b-item">
        <h3 class="route-b-name">玄學日報</h3>
        <p class="route-b-price">15U <span>/ 月</span></p>
        <p class="route-b-desc">
          八字 × 紫微 × 人類圖<br />
          每日市場能量分析<br />
          一日一次
        </p>
        <a href="#subscribe" class="arrow-link" style="margin-top: 1.5rem; display: inline-flex;">找秋爸訂閱 →</a>
      </div>

      <div class="route-b-divider" aria-hidden="true"></div>

      <div class="route-b-item">
        <h3 class="route-b-name">妖幣監測</h3>
        <p class="route-b-price">20U <span>/ 月</span></p>
        <p class="route-b-desc">
          Binance × OKX × Bitget 掃描<br />
          暴漲暴跌即時預警<br />
          Rick 自動判讀推送
        </p>
        <a href="#subscribe" class="arrow-link" style="margin-top: 1.5rem; display: inline-flex;">訂閱妖幣監測 →</a>
      </div>

      <div class="route-b-divider" aria-hidden="true"></div>

      <div class="route-b-item">
        <h3 class="route-b-name">交易指標</h3>
        <p class="route-b-price">100U <span>/ 3 個月</span></p>
        <p class="route-b-desc">
          整合七種技術分析<br />
          TradingView 上使用<br />
          入群一個月免費含在內
        </p>
        <a href="#subscribe" class="arrow-link" style="margin-top: 1.5rem; display: inline-flex;">聯絡訂閱 →</a>
      </div>
    </div>
    </div>
  </section>

  <!-- ============================================================
       Section 8 — 續留說明
       ============================================================ -->
  <section class="renewal" data-reveal="slow">
    <div class="container">
    <div class="renewal-inner">
      <h2 class="renewal-title">想要繼續留下來？</h2>
      <p class="renewal-body">
        一個月後，我們看你的交易狀況再說<br />
        適合的人，歡迎一起成為同學。
      </p>
    </div>
    </div>
  </section>

</Layout>

<style>
  /* ---- Page Hero ---- */
  .page-hero {
    padding: 160px 0 80px;
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    max-width: 12ch;
    line-height: 1.1;
    margin-top: 0.5rem;
  }

  /* ---- Full Method ---- */
  .full-method {
    padding: 80px 0;
  }

  .full-method-body {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .full-method-body p {
    font-size: 1.05rem;
    line-height: 2;
    color: var(--text);
  }

  .method-question {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--amber);
    margin-top: 0.5rem;
  }

  .method-invite {
    color: var(--text-muted) !important;
    font-style: italic;
    margin-top: 0.5rem;
  }

  /* ---- Fee Section ---- */
  .fee-section {
    padding: 80px 0;
  }

  .fee-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .fee-formula {
    border-left: 3px solid var(--amber);
    padding-left: 2rem;
    margin: 2rem 0 3rem;
  }

  .formula-main {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text);
  }

  .formula-note {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .fee-exchanges {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .fee-exchange-col {
    background: var(--bg-card);
    padding: 2rem;
  }

  .fee-exchange-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .fee-exchange-rate {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .fee-takeaway {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-top: 1rem;
  }

  .compare-exchange {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .scenarios {
    display: flex;
    flex-direction: column;
  }

  .scenario {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
  }

  .scenario-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--amber);
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  .scenario-calc {
    font-size: 1.05rem;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

