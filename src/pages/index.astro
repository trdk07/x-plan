---
// index.astro — 首頁（改版）
import Layout from '../layouts/Layout.astro';
---

<Layout title="首頁">

  <!-- ============================================================
       Section 1 — Hero（逐詞動畫）
       ============================================================ -->
  <section class="hero">
    <div class="container">
    <div class="hero-inner">
      <span class="hero-rule" data-hero></span>

      <h1 class="hero-headline" data-hero>
        <span class="word-reveal">While</span>
        <span class="word-reveal">they</span>
        <span class="word-reveal">hold,</span><br />
        <span class="word-reveal">we</span>
        <span class="word-reveal" style="color: var(--amber)">flip.</span>
      </h1>

      <p class="hero-chinese" data-hero>
        視野放小，不是退步<br />
        是另一片藍海。
      </p>

      <p class="hero-english" data-hero>
        Short frame. Clear mind. Better sleep.
      </p>

      <a href="/plans" class="btn btn-amber hero-cta" data-hero>了解方案</a>

      <p class="hero-sub" data-hero>
        一個給短線交易者的社群。玄學流日 × 技術分析 × 真實交易紀錄。
      </p>
    </div>
    </div>
  </section>

  <!-- ============================================================
       Section 2 — 打法（先建立實力感）
       ============================================================ -->
  <section class="trading-method">
    <div class="container">
    <span class="section-label" data-reveal="fade">01 &nbsp; 打法</span>
    <h2 class="trading-title" data-reveal="up">打法說清楚。</h2>

    <div class="trading-grid">
      <div class="trading-desc" data-reveal="left">
        <p>
          全倉槓桿，1–3 分鐘圖<br />
          你知道你為什麼進場，才是這裡的人。
        </p>
        <p class="trading-english">Short frame. Fast exit. Repeat.</p>
      </div>

      <div class="trading-rows" data-stagger>
        <div class="trading-row" data-reveal="up">
          <span class="trading-leverage">10×</span>
          <span class="trading-arrow">→</span>
          <span class="trading-position">1,000U 的部位</span>
        </div>
        <div class="trading-row" data-reveal="up">
          <span class="trading-leverage">50×</span>
          <span class="trading-arrow">→</span>
          <span class="trading-position">5,000U 的部位</span>
        </div>
        <div class="trading-row trading-row--highlight" data-reveal="up">
          <span class="trading-leverage trading-leverage--big">200×</span>
          <span class="trading-arrow">→</span>
          <span class="trading-position trading-position--highlight">20,000U 的部位</span>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- ============================================================
       Section 3 — 數字區（帶脈絡 + 計數動畫）
       ============================================================ -->
  <section class="stats-section">
    <div class="container">
    <div class="stats-grid" data-stagger>
      <div class="stat-block" data-reveal="up">
        <span class="stat-number" data-count="30">0</span>
        <span class="stat-unit">人</span>
        <span class="stat-label">本期名額上限</span>
        <span class="stat-context">篩選制，不開放候補</span>
      </div>
      <div class="stat-block" data-reveal="up">
        <span class="stat-number" data-count="200">0</span>
        <span class="stat-unit">×</span>
        <span class="stat-label">全倉槓桿倍數</span>
        <span class="stat-context">配合 1–3 分鐘圖，不過夜</span>
      </div>
      <div class="stat-block" data-reveal="up">
        <span class="stat-number" data-count="60">0</span>
        <span class="stat-unit">%</span>
        <span class="stat-label">玄學日報參考準確率</span>
        <span class="stat-context">我不會說更高，因為市場沒有人說得準</span>
      </div>
    </div>
    </div>
  </section>

  <!-- ============================================================
       Section 4 — 武器庫
       ============================================================ -->
  <section class="arsenal">
    <div class="container">
    <span class="section-label" data-reveal="fade">02 &nbsp; 武器庫</span>
    <h2 class="arsenal-title" data-reveal="up">加入後，你拿到這些。</h2>

    <div class="arsenal-grid" data-stagger>

      <a href="/tools" class="arsenal-card" data-reveal="up">
        <span class="arsenal-icon">卦</span>
        <h3>玄學日報</h3>
        <p>八字 × 紫微 × 人類圖<br />每日市場能量分析</p>
      </a>

      <a href="/tools" class="arsenal-card" data-reveal="up">
        <span class="arsenal-icon">⊞</span>
        <h3>TradingView 指標</h3>
        <p>專屬指標<br />配合 1–3 分鐘圖使用</p>
      </a>

      <a href="/tools" class="arsenal-card" data-reveal="up">
        <span class="arsenal-icon">◉</span>
        <h3>Binance × Bitget 監控</h3>
        <p>AI 聚合分析<br />主流幣動態直接讀</p>
      </a>

      <a href="/tools" class="arsenal-card" data-reveal="up">
        <span class="arsenal-icon">⇄</span>
        <h3>交易紀錄</h3>
        <p>真實進出場分享<br />帶邏輯，不只報明牌</p>
      </a>

      <a href="/tools" class="arsenal-card" data-reveal="up">
        <span class="arsenal-icon">◬</span>
        <h3>社群討論</h3>
        <p>30 人小群<br />不喊單，討論打法</p>
      </a>

      <a href="/tools#bitmart" class="arsenal-card" data-reveal="up">
        <span class="arsenal-icon">◇</span>
        <h3>BitMart Card</h3>
        <p>加密貨幣出金方案<br />刷卡返現最高 8%</p>
      </a>

    </div>
    </div>
  </section>

  <!-- ============================================================
       Section 5 — 爭議說明（下移，已建立信任後再坦白）
       ============================================================ -->
  <section class="dispute">
    <div class="container">
    <span class="section-label" data-reveal="fade">03 &nbsp; 坦白說</span>
    <h2 class="dispute-title" data-reveal="up">先說清楚幾件事。</h2>

    <div class="dispute-body" data-reveal="up">
      <p>
        我打高槓桿。持倉時間短，有時候就幾分鐘<br />
        手續費綜合計算確實比較多，你使用我的邀請碼<br />
        我也確實有獲得返傭。
      </p>

      <p class="dispute-truth">這些都是真的。</p>

      <p>
        但在流動性變慢、長時區多空難判的市場裡<br />
        長時間持倉是很穩健想法，但想要在短時間拿到高利潤<br />
        不是容易的事。
      </p>

      <p>
        我選擇短進短出，看得見的利潤<br />
        睡得著的夜晚。
      </p>
    </div>

    <p class="dispute-english" data-reveal="fade">
      The math works. The plan is simple. The execution is honest.
    </p>
    </div>
  </section>

  <!-- ============================================================
       Section 6 — CTA
       ============================================================ -->
  <section class="cta-section">
    <div class="cta-inner" data-reveal="up">
      <h2 class="cta-title">本期限收 30 人。</h2>

      <div class="cta-body">
        <p>免費開始，但不是人人都能留下來。</p>
        <p>
          如果你的虧損到了某個程度<br />
          我會請你離開。
        </p>
        <p>
          不是懲罰，而是我的方式可能真的不適合你<br />
          這是沒關係的，一定有更適合你的交易計畫
        </p>
      </div>

      <p class="cta-english">
        This isn't for everyone<br />
        But if it's for you, you'll know.
      </p>

      <div class="cta-buttons">
        <a href="/plans" class="btn btn-amber">了解方案</a>
        <a href="#" class="btn btn-ghost">先加入大群</a>
      </div>
    </div>
  </section>

</Layout>

<!-- 逐詞動畫 + 計數動畫腳本 -->
<script>
  // 逐詞動畫
  document.addEventListener('DOMContentLoaded', () => {
    const words = document.querySelectorAll('.word-reveal');
    words.forEach((word, i) => {
      word.style.opacity = '0';
      word.style.transform = 'translateY(18px)';
      word.style.transition = `opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${i * 0.1 + 0.3}s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${i * 0.1 + 0.3}s`;
      word.style.display = 'inline-block';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          word.style.opacity = '1';
          word.style.transform = 'translateY(0)';
        });
      });
    });

    // 數字計數動畫
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.dataset.count, 10);
        const duration = 1200;
        const start = performance.now();

        function tick(now) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(target * eased);
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        countObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('[data-count]').forEach(el => countObserver.observe(el));
  });
</script>

<style>
  /* ---- Hero ---- */
  .hero {
    height: 100vh;
    background: var(--bg);
    background-image: radial-gradient(ellipse 80% 60% at 85% 85%, rgba(196, 168, 74, 0.08) 0%, transparent 70%);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero .container { width: 100%; }

  .hero-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 820px;
  }

  .hero-rule {
    display: block;
    width: 100px;
    height: 1px;
    background: var(--amber);
    margin-bottom: 2.5rem;
  }

  .hero-headline {
    font-size: clamp(3rem, 7vw, 7rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--text);
    max-width: 14ch;
  }

  .word-reveal {
    display: inline-block;
    margin-right: 0.25em;
  }

  .hero-chinese {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--text-muted);
    margin-top: 2rem;
    line-height: 1.9;
  }

  .hero-english {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-top: 1.5rem;
  }

  .hero-cta {
    margin-top: 3rem;
    align-self: flex-start;
  }

  .hero-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 1.2rem;
  }

  /* ---- Section Label ---- */
  .section-label {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .section-label::after {
    content: '';
    width: 36px;
    height: 1px;
    background: var(--amber);
    opacity: 0.4;
  }

  /* ---- 打法 ---- */
  .trading-method {
    padding: 120px 0;
  }

  .trading-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .trading-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .trading-desc p {
    font-size: 1.1rem;
    line-height: 2;
    color: var(--text);
  }

  .trading-english {
    margin-top: 2rem;
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    color: var(--amber);
  }

  .trading-rows {
    max-width: 560px;
  }

  .trading-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .trading-leverage {
    color: var(--amber);
    font-size: 1.5rem;
    font-weight: 700;
    min-width: 80px;
  }

  .trading-leverage--big {
    font-size: 2rem;
    font-weight: 800;
  }

  .trading-arrow { color: var(--text-muted); font-size: 1rem; }
  .trading-position { color: var(--text-muted); font-size: 1rem; }
  .trading-position--highlight { color: var(--text); font-weight: 600; }

  /* ---- 數字區 ---- */
  .stats-section {
    padding: 100px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }

  .stat-number {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 300;
    color: var(--amber);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-unit {
    font-size: 1.5rem;
    color: var(--amber);
    font-weight: 300;
    margin-top: 0.25rem;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text);
    margin-top: 1rem;
    letter-spacing: 0.04em;
  }

  .stat-context {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    line-height: 1.5;
    max-width: 200px;
  }

  /* ---- 武器庫 ---- */
  .arsenal {
    padding: 120px 0;
  }

  .arsenal-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin-bottom: 3.5rem;
  }

  .arsenal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .arsenal-card {
    background: var(--bg-card);
    padding: 2.5rem 2rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.3s var(--ease-out);
    display: flex;
    flex-direction: column;
  }

  .arsenal-card:hover {
    background: #1a2a1c;
  }

  .arsenal-icon {
    font-size: 1.5rem;
    color: var(--amber);
    margin-bottom: 1.25rem;
    line-height: 1;
  }

  .arsenal-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .arsenal-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ---- 爭議說明 ---- */
  .dispute {
    padding: 120px 0;
  }

  .dispute-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .dispute-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 640px;
  }

  .dispute-body p {
    font-size: 1.1rem;
    line-height: 1.95;
    color: var(--text);
  }

  .dispute-truth {
    color: var(--red) !important;
    font-size: 1.25rem !important;
    font-weight: 600;
    margin: 0.5rem 0 !important;
  }

  .dispute-english {
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    color: var(--amber);
    margin-top: 3rem;
  }

  /* ---- CTA ---- */
  .cta-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 0;
  }

  .cta-inner { max-width: 560px; }

  .cta-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: var(--amber);
    margin-bottom: 2rem;
  }

  .cta-body {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .cta-body p {
    font-size: 1rem;
    line-height: 1.9;
    max-width: 480px;
    margin: 0 auto;
    color: var(--text);
  }

  .cta-english {
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin: 2.5rem auto;
    line-height: 1.8;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 3rem;
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .trading-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .stat-block {
      padding: 2rem 1rem;
      border-bottom: 1px solid var(--border);
    }

    .stat-block:last-child {
      border-bottom: none;
    }

    .arsenal-grid {
      grid-template-columns: 1fr 1fr;
    }

    .trading-row { gap: 1rem; }
  }

  @media (max-width: 480px) {
    .arsenal-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
