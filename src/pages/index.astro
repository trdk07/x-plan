<!-- 逐詞動畫 + 計數動畫腳本（等 splash 結束後才觸發） -->
<script>
  // 隱藏逐詞元素（立即）
  const words = document.querySelectorAll('.word-reveal');
  words.forEach((word: HTMLElement) => {
    word.style.opacity = '0';
    word.style.transform = 'translateY(18px)';
    word.style.display = 'inline-block';
  });

  function startWordReveal() {
    words.forEach((word: HTMLElement, i: number) => {
      word.style.transition = `opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${i * 0.1 + 0.3}s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${i * 0.1 + 0.3}s`;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          word.style.opacity = '1';
          word.style.transform = 'translateY(0)';
        });
      });
    });
  }

  function startCounters() {
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.count!, 10);
        const duration = 1200;
        const start = performance.now();

        function tick(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = String(Math.round(target * eased));
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        countObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('[data-count]').forEach(el => countObserver.observe(el));
  }

  if (document.getElementById('splash')) {
    document.addEventListener('splash-exited', () => {
      startWordReveal();
      startCounters();
    });
  } else {
    document.addEventListener('DOMContentLoaded', () => {
      startWordReveal();
      startCounters();
    });
  }
</script>

<style>
  /* ---- Hero ---- */
  .hero {
    height: 100vh;
    background: var(--bg);
    background-image: radial-gradient(ellipse 80% 60% at 85% 85%, rgba(196, 168, 74, 0.08) 0%, transparent 70%);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero .container { width: 100%; }

  .hero-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 820px;
  }

  .hero-rule {
    display: block;
    width: 100px;
    height: 1px;
    background: var(--amber);
    margin-bottom: 2.5rem;
  }

  .hero-headline {
    font-size: clamp(3rem, 7vw, 7rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--text);
    max-width: 14ch;
  }

  .word-reveal {
    display: inline-block;
    margin-right: 0.25em;
  }

  .hero-chinese {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--text-muted);
    margin-top: 2rem;
    line-height: 1.9;
  }

  .hero-english {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-top: 1.5rem;
  }

  .hero-cta {
    margin-top: 3rem;
    align-self: flex-start;
  }

  .hero-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 1.2rem;
  }

  /* ---- Section Label ---- */
  .section-label {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .section-label::after {
    content: '';
    width: 36px;
    height: 1px;
    background: var(--amber);
    opacity: 0.4;
  }

  /* ---- 打法 ---- */
  .trading-method {
    padding: 120px 0;
  }

  .trading-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .trading-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .trading-desc p {
    font-size: 1.1rem;
    line-height: 2;
    color: var(--text);
  }

  .trading-english {
    margin-top: 2rem;
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    color: var(--amber);
  }

  .trading-rows {
    max-width: 560px;
  }

  .trading-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .trading-leverage {
    color: var(--amber);
    font-size: 1.5rem;
    font-weight: 700;
    min-width: 80px;
  }

  .trading-leverage--big {
    font-size: 2rem;
    font-weight: 800;
  }

  .trading-arrow { color: var(--text-muted); font-size: 1rem; }
  .trading-position { color: var(--text-muted); font-size: 1rem; }
  .trading-position--highlight { color: var(--text); font-weight: 600; }

  /* ---- 數字區 ---- */
  .stats-section {
    padding: 100px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }

  .stat-number {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 300;
    color: var(--amber);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-unit {
    font-size: 1.5rem;
    color: var(--amber);
    font-weight: 300;
    margin-top: 0.25rem;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text);
    margin-top: 1rem;
    letter-spacing: 0.04em;
  }

  .stat-context {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    line-height: 1.5;
    max-width: 200px;
  }

  /* ---- 武器庫 ---- */
  .arsenal {
    padding: 120px 0;
  }

  .arsenal-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin-bottom: 3.5rem;
  }

  .arsenal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .arsenal-card {
    background: var(--bg-card);
    padding: 2.5rem 2rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.4s var(--ease-out), transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
    display: flex;
    flex-direction: column;
    cursor: default;
    position: relative;
    overflow: hidden;
  }

  .arsenal-card::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
    background: radial-gradient(ellipse at 50% 0%, rgba(196, 168, 74, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .arsenal-card:hover {
    background: #1a2a1c;
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(196, 168, 74, 0.1);
  }

  .arsenal-card:hover::after {
    opacity: 1;
  }

  .arsenal-card:hover .arsenal-icon {
    transform: scale(1.1);
  }

  .arsenal-icon {
    font-size: 1.5rem;
    color: var(--amber);
    margin-bottom: 1.25rem;
    line-height: 1;
    transition: transform 0.4s var(--ease-out);
  }

  .arsenal-icon--svg {
    font-size: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .arsenal-icon--svg svg {
    width: 26px;
    height: 26px;
  }

  .arsenal-icon--dual svg {
    width: 22px;
    height: 22px;
  }

  .arsenal-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .arsenal-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ---- 交易所推薦 ---- */
  .exchange-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .exchange-heading {
    font-size: 1.1rem;
